{
    "name": "index",
    "operation-type": "bulk-index",
    "bulk-size": {{bulk_size | default(10000)}},
    "ingest-percentage": {{ingest_percentage | default(100)}}
  },
  {
    "name": "update",
    "operation-type": "bulk-index",
    "bulk-size": {{bulk_size | default(10000)}},
    "ingest-percentage": {{ingest_percentage | default(100)}},
    "conflicts": "{{conflicts | default('random')}}",
    "on-conflict": "{{on_conflict | default('update')}}",
    "conflict-probability": {{conflict_probability | default(25)}},
    "recency": {{recency | default(0)}}
  },
  {
    "name": "wait-until-merges-finish",
    "operation-type": "wait-for-merges",
    "retry-wait-period": 2.0,
    "max-wait-seconds": 600,
    "include-in-reporting": false
  },
  {
    "name": "match-all",
    "operation-type": "search",
    "body": {
      "query": "*:*"
    }
  },
  {
    "name": "range",
    "operation-type": "search",
    "body": {
      "query": "total_amount:[5 TO 15]"
    }
  },
  {
    "name": "distance_amount_facet",
    "operation-type": "search",
    "body": {
      "query": "*:*",
      "filter": [
        "trip_distance:[0 TO 50]"
      ],
      "limit": 0,
      "facet": {
        "distance_histo": {
          "type": "range",
          "field": "trip_distance",
          "gap": 1,
          "mincount": 1,
          "start": 0,
          "end": 51
        }
      }
    }
  },
  {
    "name": "date_histogram_facet",
    "operation-type": "search",
    "body": {
      "query": "dropoff_datetime:[2015-01-01T00:00:00Z TO 2015-01-21T00:00:00Z]",
      "limit": 0,
      "facet": {
        "dropoffs_over_time": {
          "type": "range",
          "field": "dropoff_datetime",
          "gap": "+1DAY",
          "mincount": 1,
          "start": "2015-01-01T00:00:00Z",
          "end": "2015-01-22T00:00:00Z"
        }
      }
    }
  },
  {
    "name": "date_histogram_calendar_interval",
    "operation-type": "search",
    "body": {
      "query": "dropoff_datetime:[2015-01-01T00:00:00Z TO 2016-01-01T00:00:00Z]",
      "limit": 0,
      "facet": {
        "dropoffs_over_time": {
          "type": "range",
          "field": "dropoff_datetime",
          "gap": "+1MONTH",
          "mincount": 1,
          "start": "2015-01-01T00:00:00Z",
          "end": "2016-01-01T00:00:00Z"
        }
      }
    }
  },
  {
    "name": "date_histogram_fixed_interval",
    "operation-type": "search",
    "body": {
      "query": "dropoff_datetime:[2015-01-01T00:00:00Z TO 2016-01-01T00:00:00Z]",
      "limit": 0,
      "facet": {
        "dropoffs_over_time": {
          "type": "range",
          "field": "dropoff_datetime",
          "gap": "+30DAY",
          "mincount": 1,
          "start": "2015-01-01T00:00:00Z",
          "end": "2016-01-01T00:00:00Z"
        }
      }
    }
  },
  {
    "name": "desc_sort_tip_amount",
    "operation-type": "search",
    "body": {
      "query": "*:*",
      "sort": "tip_amount desc"
    }
  },
  {
    "name": "asc_sort_tip_amount",
    "operation-type": "search",
    "body": {
      "query": "*:*",
      "sort": "tip_amount asc"
    }
  },
  {
    "name": "desc_sort_passenger_count",
    "operation-type": "search",
    "body": {
      "query": "*:*",
      "sort": "passenger_count desc"
    }
  },
  {
    "name": "asc_sort_passenger_count",
    "operation-type": "search",
    "body": {
      "query": "*:*",
      "sort": "passenger_count asc"
    }
  }
