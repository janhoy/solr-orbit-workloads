    {
      "name": "search-longevity-test",
      "description": "Indexes half the data for NYC Taxis, then concurrently queries Solr while indexing again.",
      "default": false,
      "schedule": [
        {% with collection_name="nyc_taxis" %}
        {{ benchmark.collect(parts="../../common_operations/delete_collection.json") }},
        {% endwith %}
        {% with collection_name="nyc_taxis", configset_path="configsets/nyc_taxis" %}
        {{ benchmark.collect(parts="../../common_operations/create_collection.json") }},
        {% endwith %}
        {{ benchmark.collect(parts="../../common_operations/check_cluster_health.json") }},
        {
          "name": "initial-index-append",
          "operation": {
            "operation-type": "bulk-index",
            "bulk-size": {{bulk_size | default(10000)}},
            "ingest-percentage": 50
          },
          "warmup-time-period": 30,
          "clients": {{bulk_indexing_clients | default(8)}},
          "ignore-response-error-level": "{{error_level | default('non-fatal')}}"
        },
        {
          "name": "refresh-after-index",
          "operation": {
            "operation-type": "commit",
            "collection": "nyc_taxis"
          }
        },
        {{ benchmark.collect(parts="../../common_operations/optimize.json") }},
        {
          "parallel": {
            "tasks": [
              {
                "name": "concurrent-index-append",
                "operation": {
                  "operation-type": "bulk-index",
                  "bulk-size": {{bulk_size | default(10000)}},
                  "ingest-percentage": 50
                },
                "clients": {{bulk_indexing_clients | default(8)}},
                "ignore-response-error-level": "{{error_level | default('non-fatal')}}"
              },
              {
                "operation": "match-all",
                "time-period": {{ default_time_period or time_period | default(300) | tojson }},
                "target-throughput": {{ default_target_throughput or target_throughput | default(3) | tojson }},
                "clients": {{ default_search_clients or search_clients | default(1) }}
              },
              {
                "operation": "range",
                "time-period": {{ range_time_period or time_period | default(300) | tojson }},
                "target-throughput": {{ range_target_throughput or target_throughput | default(0.7) | tojson }},
                "clients": {{ range_search_clients or search_clients | default(1) }}
              },
              {
                "operation": "distance_amount_facet",
                "time-period": {{ distance_amount_facet_time_period or time_period | default(300) | tojson }},
                "target-throughput": {{ distance_amount_facet_target_throughput or target_throughput | default(2) | tojson }},
                "clients": {{ distance_amount_facet_search_clients or search_clients | default(1) }}
              },
              {
                "operation": "date_histogram_facet",
                "time-period": {{ date_histogram_facet_time_period or time_period | default(300) | tojson }},
                "target-throughput": {{ date_histogram_facet_target_throughput or target_throughput | default(1.5) | tojson }},
                "clients": {{ date_histogram_facet_search_clients or search_clients | default(1) }}
              },
              {
                "operation": "desc_sort_tip_amount",
                "time-period": {{ desc_sort_tip_amount_time_period or time_period | default(300) | tojson }},
                "target-throughput": {{ desc_sort_tip_amount_target_throughput or target_throughput | default(0.5) | tojson }},
                "clients": {{ desc_sort_tip_amount_search_clients or search_clients | default(1) }}
              },
              {
                "operation": "asc_sort_tip_amount",
                "time-period": {{ asc_sort_tip_amount_time_period or time_period | default(300) | tojson }},
                "target-throughput": {{ asc_sort_tip_amount_target_throughput or target_throughput | default(0.5) | tojson }},
                "clients": {{ asc_sort_tip_amount_search_clients or search_clients | default(1) }}
              },
              {
                "name": "cluster-status-loop",
                "operation": {
                  "operation-type": "raw-request",
                  "method": "GET",
                  "path": "/solr/admin/collections?action=CLUSTERSTATUS&collection=nyc_taxis&wt=json"
                },
                "clients": 1,
                "target-interval": 10,
                "time-period": {{ default_time_period or time_period | default(300) | tojson }}
              },
              {
                "name": "commit-loop",
                "operation": {
                  "operation-type": "commit",
                  "collection": "nyc_taxis"
                },
                "clients": 1,
                "target-interval": 30,
                "time-period": {{ default_time_period or time_period | default(300) | tojson }}
              }
            ]
          }
        }
      ]
    },
    {
      "name": "indexing-search-longevity-test",
      "description": "Concurrently indexes and queries NYC Taxis data in Solr.",
      "default": false,
      "schedule": [
        {% with collection_name="nyc_taxis" %}
        {{ benchmark.collect(parts="../../common_operations/delete_collection.json") }},
        {% endwith %}
        {% with collection_name="nyc_taxis", configset_path="configsets/nyc_taxis" %}
        {{ benchmark.collect(parts="../../common_operations/create_collection.json") }},
        {% endwith %}
        {{ benchmark.collect(parts="../../common_operations/check_cluster_health.json") }},
        {
          "parallel": {
            "tasks": [
              {
                "name": "index-append",
                "operation": {
                  "operation-type": "bulk-index",
                  "bulk-size": {{bulk_size | default(10000)}},
                  "looped": true
                },
                "clients": {{bulk_indexing_clients | default(8)}},
                "time-period": {{ default_time_period or time_period | default(300) | tojson }}
              },
              {
                "operation": "match-all",
                "time-period": {{ default_time_period or time_period | default(300) | tojson }},
                "target-throughput": {{ default_target_throughput or target_throughput | default(3) | tojson }},
                "clients": {{ default_search_clients or search_clients | default(1) }}
              },
              {
                "operation": "range",
                "time-period": {{ range_time_period or time_period | default(300) | tojson }},
                "target-throughput": {{ range_target_throughput or target_throughput | default(0.7) | tojson }},
                "clients": {{ range_search_clients or search_clients | default(1) }}
              },
              {
                "operation": "distance_amount_facet",
                "time-period": {{ distance_amount_facet_time_period or time_period | default(300) | tojson }},
                "target-throughput": {{ distance_amount_facet_target_throughput or target_throughput | default(2) | tojson }},
                "clients": {{ distance_amount_facet_search_clients or search_clients | default(1) }}
              },
              {
                "operation": "date_histogram_facet",
                "time-period": {{ date_histogram_facet_time_period or time_period | default(300) | tojson }},
                "target-throughput": {{ date_histogram_facet_target_throughput or target_throughput | default(1.5) | tojson }},
                "clients": {{ date_histogram_facet_search_clients or search_clients | default(1) }}
              },
              {
                "operation": "desc_sort_tip_amount",
                "time-period": {{ desc_sort_tip_amount_time_period or time_period | default(300) | tojson }},
                "target-throughput": {{ desc_sort_tip_amount_target_throughput or target_throughput | default(0.5) | tojson }},
                "clients": {{ desc_sort_tip_amount_search_clients or search_clients | default(1) }}
              },
              {
                "operation": "asc_sort_tip_amount",
                "time-period": {{ asc_sort_tip_amount_time_period or time_period | default(300) | tojson }},
                "target-throughput": {{ asc_sort_tip_amount_target_throughput or target_throughput | default(0.5) | tojson }},
                "clients": {{ asc_sort_tip_amount_search_clients or search_clients | default(1) }}
              },
              {
                "name": "cluster-status-loop",
                "operation": {
                  "operation-type": "raw-request",
                  "method": "GET",
                  "path": "/solr/admin/collections?action=CLUSTERSTATUS&collection=nyc_taxis&wt=json"
                },
                "clients": 1,
                "target-interval": 10,
                "time-period": {{ default_time_period or time_period | default(300) | tojson }}
              },
              {
                "name": "commit-loop",
                "operation": {
                  "operation-type": "commit",
                  "collection": "nyc_taxis"
                },
                "clients": 1,
                "target-interval": 30,
                "time-period": {{ default_time_period or time_period | default(300) | tojson }}
              }
            ]
          }
        }
      ]
    }
